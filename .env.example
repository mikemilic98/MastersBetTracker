# Copy to `.env` and adjust. Never commit `.env`.

# SQLite (file relative to prisma/ directory)
DATABASE_URL="file:./prisma/dev.db"

# Pool gate + admin (set before production)
POOL_KEY="change-me-pool-secret"
ADMIN_KEY="change-me-admin-secret"

# Optional: public leaderboard API without pool cookie (true/false)
# LEADERBOARD_PUBLIC="true"

# Optional: URL for HTML leaderboard scrape (implement later)
SCRAPE_LEADERBOARD_URL="http://127.0.0.1:8765/sample-leaderboard.html"

# Optional: protect GET /api/cron/refresh-snapshots (Vercel Cron sends Bearer CRON_SECRET)
# CRON_SECRET="long-random-string"

# Scrape polling (default 10s): run alongside the app — npm run scrape:poll
# (export vars from this file first, or use: node --env-file=.env scripts/poll-scrape.mjs)
# Vercel Cron cannot run faster than once/minute; vercel.json uses */1 * * * * for that.
# SCRAPER_POLL_INTERVAL_SECONDS=10
# SCRAPER_POLL_BASE_URL=http://127.0.0.1:3000
